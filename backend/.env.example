# Environment variables for Welcome Enterprises API
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────
# MongoDB Atlas
# ─────────────────────────────────────────────
# MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/welcome_enterprises?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://mohameddriyaz2710_db_user:B7V2XXKfHFvJ1sEM@cluster0.9dcrjnn.mongodb.net/taj_real_estate?retryWrites=true&w=majority
# ─────────────────────────────────────────────
# JWT Secrets (use long random strings in production)
# ─────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────
# Admin Seed (first-run only)
# ─────────────────────────────────────────────
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@welcomeenterprises.com
